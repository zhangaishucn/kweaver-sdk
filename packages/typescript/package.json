{
  "name": "@kweaver-ai/kweaver-sdk",
  "version": "0.6.9",
  "description": "KWeaver TypeScript SDK — CLI tool and programmatic API for knowledge networks and Decision Agents.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./kweaver": {
      "import": "./dist/kweaver.js",
      "types": "./dist/kweaver.d.ts"
    }
  },
  "bin": {
    "kweaver": "bin/kweaver.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc -p tsconfig.json && (cp -r src/templates dist/ 2>/dev/null || true)",
    "start": "node ./dist/cli.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test test/*.test.ts",
    "test:e2e": "node --import tsx --test test/e2e/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "typescript",
    "kweaver"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kweaver-ai/kweaver-sdk.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.14",
    "@types/yargs": "^17.0.35",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@kweaver-ai/bkn": "^0.1.0",
    "chardet": "^2.1.1",
    "columnify": "^1.6.0",
    "csv-parse": "^6.2.1",
    "iconv-lite": "^0.7.2",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^11.2.0",
    "react": "^19.2.4",
    "string-width": "^8.2.0",
    "yargs": "^18.0.0"
  }
}
